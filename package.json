{
  "name": "claude-shell",
  "version": "2.0.0",
  "description": "Desktop UI for Claude Code — Tauri + Bun. Chat, editor, terminal, approvals, history, usage.",
  "author": "Dylan",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:sidecar": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "bun run typecheck:sidecar && bun run typecheck:web",
    "dev": "tauri dev",
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "build": "tauri build",
    "sidecar": "bun run src/sidecar/index.ts",
    "tauri": "tauri"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.198",
    "@codemirror/merge": "6.12.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@uiw/codemirror-extensions-langs": "4.25.10",
    "@uiw/codemirror-theme-vscode": "4.25.10",
    "@uiw/react-codemirror": "4.25.10",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "clsx": "2.1.1",
    "diff": "9.0.0",
    "lucide-react": "1.23.0",
    "react-diff-viewer-continued": "4.2.2",
    "react-markdown": "10.1.0",
    "rehype-highlight": "7.0.2",
    "remark-gfm": "4.0.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "bun-types": "^1.3.14",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "17.7.0",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "4.3.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.62.1",
    "vite": "^7.2.6"
  }
}
