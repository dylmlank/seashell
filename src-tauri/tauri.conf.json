{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Shell",
  "version": "2.0.0",
  "identifier": "com.claude-shell.app",
  "build": {
    "beforeDevCommand": "bun run dev:renderer",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun run build:renderer",
    "frontendDist": "../out/renderer"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Shell",
        "width": 1280,
        "height": 840,
        "minWidth": 800,
        "minHeight": 500,
        "dragDropEnabled": false,
        "backgroundColor": "#0a0a0a"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"]
  }
}
