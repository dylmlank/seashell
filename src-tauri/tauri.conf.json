{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Seashell",
  "version": "0.1.0",
  "identifier": "com.claude-shell.app",
  "build": {
    "beforeDevCommand": "bun run dev:renderer",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun run build:renderer && bun run build:sidecar",
    "frontendDist": "../out/renderer"
  },
  "app": {
    "windows": [
      {
        "title": "Seashell",
        "width": 1280,
        "height": 840,
        "minWidth": 800,
        "minHeight": 500,
        "dragDropEnabled": true,
        "backgroundColor": "#0a0a0a"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ws://127.0.0.1:* ipc: http://ipc.localhost; frame-src 'self' data: http://localhost:* http://127.0.0.1:* https://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "app",
      "dmg",
      "appimage",
      "deb"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/sidecar/": "sidecar/"
    }
  }
}
